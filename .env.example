# Copy to .env.local and fill in your own values.
# .env.local is gitignored — never commit secrets.

# Public Supabase values (safe to ship in browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only secret (used by local scripts only, NEVER ships to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App settings (event details shown on invitation page)
NEXT_PUBLIC_EVENT_TITLE=Your Event Title
NEXT_PUBLIC_EVENT_DATE=DD.MM.YY
NEXT_PUBLIC_EVENT_VENUE=Your Venue Address
